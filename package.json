{
  "scripts": {
    "build": "pnpm --filter create-vocs build && pnpm --filter @vocs/twoslash-rust build && pnpm --filter @vocs/twoslash-rust build:npm && node scripts/build-openapi-standalone.ts && zile",
    "clean": "tsc -b --clean && rm -rf dist",
    "changeset:publish": "pnpm build && zile publish:prepare && changeset publish && zile publish:post",
    "changeset:version": "changeset version",
    "check": "biome check --fix --unsafe",
    "check:types": "tsc -b",
    "dev": "pnpm --filter create-vocs dev && zile dev",
    "dev:playground": "pnpm --filter playground dev",
    "dev:playground:twoslash": "cd playground && tsx ../src/cli.ts twoslash",
    "docs:build": "pnpm --filter site build",
    "docs:dev": "pnpm --filter site dev",
    "docs:preview": "pnpm --filter site preview",
    "docs:twoslash": "cd site && tsx ../src/cli.ts twoslash",
    "postinstall": "pnpm dev",
    "test": "vitest ./src",
    "test:twoslash-rust": "cargo test --manifest-path twoslash-rust/Cargo.toml"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@changesets/cli": "catalog:",
    "@types/estree": "^1.0.8",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "astring": "^1.9.0",
    "jsdom": "^28.1.0",
    "mermaid": "^11.12.2",
    "react": "catalog:",
    "react-dom": "catalog:",
    "simple-git-hooks": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "waku": "catalog:",
    "zile": "catalog:"
  },
  "packageManager": "pnpm@10.25.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.5.0",
      "onFail": "download"
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check"
  },
  "[!start-pkg]": "",
