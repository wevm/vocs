    }
  },
  "sideEffects": false,
  "bin": {
    "vocs": "./dist/cli.js"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "src": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "src": "./src/config.ts",
      "default": "./dist/config.js"
    },
    "./globals": {
      "types": "./dist/globals.d.ts",
      "src": "./src/globals.d.ts"
    },
    "./mdx": {
      "types": "./dist/mdx.d.ts",
      "src": "./src/mdx.tsx",
      "default": "./dist/mdx.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "src": "./src/server/index.ts",
      "default": "./dist/server/index.js"
    },
    "./server/*": {
      "types": "./dist/server/*.d.ts",
      "src": "./src/server/*",
      "default": "./dist/server/*.js"
    },
    "./waku/internal/routes/*": {
      "types": "./dist/waku/internal/routes/*.d.ts",
      "src": "./src/waku/internal/routes/*.tsx",
      "default": "./dist/waku/internal/routes/*.js"
    },
    "./waku/internal": {
      "types": "./dist/waku/internal/index.d.ts",
      "src": "./src/waku/internal/index.ts",
      "default": "./dist/waku/internal/index.js"
    },
    "./waku/internal/patches/adapters/vercel": {
      "types": "./dist/waku/internal/patches/adapters/vercel.d.ts",
      "src": "./src/waku/internal/patches/adapters/vercel.ts",
      "default": "./dist/waku/internal/patches/adapters/vercel.js"
    },
    "./waku/internal/patches/adapters/node": {
      "types": "./dist/waku/internal/patches/adapters/node.d.ts",
