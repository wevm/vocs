{
  "name": "@vocs/twoslash-rust",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "twoslash-rust": "./bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin.js"
  ],
  "scripts": {
    "build": "tsc",
    "build:rust": "cargo build --release",
    "build:npm": "node --experimental-strip-types scripts/build-npm.ts"
  },
  "dependencies": {
    "detect-libc": "^2.0.3"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@vocs/twoslash-rust-darwin-arm64": "workspace:*",
    "@vocs/twoslash-rust-darwin-x64": "workspace:*",
    "@vocs/twoslash-rust-linux-x64-gnu": "workspace:*"
  }
}
